import React from 'react';
import { NavigationContainer } from '@react-navigation/native';
import { createStackNavigator } from '@react-navigation/stack';
import { StatusBar } from 'expo-status-bar';
import { View, Text, StyleSheet, TouchableOpacity, ScrollView } from 'react-native';
import { Ionicons } from '@expo/vector-icons';

// ============================================================
// HOME SCREEN
// ============================================================
function HomeScreen({ navigation }: any) {
  return (
    <ScrollView style={styles.container} contentContainerStyle={styles.content}>
      <View style={styles.header}>
        <Text style={styles.headerTitle}>Build Your Dream App</Text>
        <Text style={styles.headerSubtitle}>
          Professional app development tailored to your business needs.
        </Text>
      </View>

      <View style={styles.servicesContainer}>
        <Text style={styles.sectionTitle}>Our Services</Text>
        <View style={styles.servicesGrid}>
          <View style={styles.serviceCard}>
            <Ionicons name="phone-portrait" size={32} color="#4F46E5" />
            <Text style={styles.serviceTitle}>Mobile Apps</Text>
            <Text style={styles.servicePrice}>From $1,599</Text>
          </View>
          <View style={styles.serviceCard}>
            <Ionicons name="laptop" size={32} color="#4F46E5" />
            <Text style={styles.serviceTitle}>Web Apps</Text>
            <Text style={styles.servicePrice}>From $899</Text>
          </View>
          <View style={styles.serviceCard}>
            <Ionicons name="server" size={32} color="#4F46E5" />
            <Text style={styles.serviceTitle}>Backend Systems</Text>
            <Text style={styles.servicePrice}>From $979</Text>
          </View>
          <View style={styles.serviceCard}>
            <Ionicons name="headset" size={32} color="#4F46E5" />
            <Text style={styles.serviceTitle}>24/7 Support</Text>
            <Text style={styles.servicePrice}>From $299/mo</Text>
          </View>
        </View>
      </View>

      <TouchableOpacity
        style={styles.ctaButton}
        onPress={() => navigation.navigate('Consultation')}
      >
        <Text style={styles.ctaText}>Get Free Consultation</Text>
      </TouchableOpacity>

      <TouchableOpacity
        style={styles.portfolioButton}
        onPress={() => navigation.navigate('Portfolio')}
      >
        <Text style={styles.portfolioText}>View Our Work</Text>
      </TouchableOpacity>
    </ScrollView>
  );
}

// ============================================================
// CONSULTATION SCREEN
// ============================================================
function ConsultationScreen({ navigation }: any) {
  return (
    <View style={styles.consultationContainer}>
      <Text style={styles.title}>Free Consultation</Text>
      <Text style={styles.subtitle}>Tell us about your app idea</Text>
      <View style={styles.formCard}>
        <Text style={styles.formMessage}>Consultation form will appear here</Text>
        <TouchableOpacity
          style={styles.submitButton}
          onPress={() => navigation.navigate('ThankYou')}
        >
          <Text style={styles.submitText}>Submit</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

// ============================================================
// PORTFOLIO SCREEN
// ============================================================
function PortfolioScreen() {
  return (
    <View style={styles.consultationContainer}>
      <Text style={styles.title}>Our Portfolio</Text>
      <Text style={styles.subtitle}>Explore our successful projects</Text>
      <View style={styles.formCard}>
        <Text style={styles.formMessage}>Portfolio items will appear here</Text>
      </View>
    </View>
  );
}

// ============================================================
// THANK YOU SCREEN
// ============================================================
function ThankYouScreen({ navigation }: any) {
  return (
    <View style={styles.consultationContainer}>
      <View style={styles.thankYouCard}>
        <Text style={styles.emoji}>✅</Text>
        <Text style={styles.thankYouTitle}>Thank You!</Text>
        <Text style={styles.thankYouSubtitle}>We'll contact you within 24 hours.</Text>
        <TouchableOpacity
          style={styles.submitButton}
          onPress={() => navigation.navigate('Home')}
        >
          <Text style={styles.submitText}>Back to Home</Text>
        </TouchableOpacity>
      </View>
    </View>
  );
}

// ============================================================
// ADMIN DASHBOARD SCREEN
// ============================================================
function AdminScreen() {
  return (
    <View style={styles.consultationContainer}>
      <Text style={styles.title}>Admin Dashboard</Text>
      <Text style={styles.subtitle}>Manage your consultations</Text>
      <View style={styles.formCard}>
        <Text style={styles.formMessage}>No consultations yet</Text>
      </View>
    </View>
  );
}

// ============================================================
// NAVIGATION
// ============================================================
const Stack = createStackNavigator();

export default function App() {
  return (
    <NavigationContainer>
      <StatusBar style="auto" />
      <Stack.Navigator
        initialRouteName="Home"
        screenOptions={{
          headerStyle: { backgroundColor: '#4F46E5' },
          headerTintColor: '#fff',
          headerTitleStyle: { fontWeight: 'bold' },
        }}
      >
        <Stack.Screen
          name="Home"
          component={HomeScreen}
          options={{ title: 'ImagineMyApps' }}
        />
        <Stack.Screen
          name="Consultation"
          component={ConsultationScreen}
          options={{ title: 'Free Consultation' }}
        />
        <Stack.Screen
          name="Portfolio"
          component={PortfolioScreen}
          options={{ title: 'Our Portfolio' }}
        />
        <Stack.Screen
          name="ThankYou"
          component={ThankYouScreen}
          options={{ title: 'Thank You' }}
        />
        <Stack.Screen
          name="Admin"
          component={AdminScreen}
          options={{ title: 'Admin Dashboard' }}
        />
      </Stack.Navigator>
    </NavigationContainer>
  );
}

